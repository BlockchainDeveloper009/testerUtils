{
  "name": "testerutils",
  "version": "1.0.0",
  "description": "Comprehensive test automation utilities with structured logging, API helpers, and file operations",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "lint": "eslint src tests --ext .ts,.tsx",
    "lint:fix": "eslint src tests --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "test:dev": "ENV_LOC=dev npx playwright test",
    "test:stage": "ENV_LOC=stage npx playwright test",
    "test:config": "npx playwright test example_configuration.spec.ts --ui",
    "test:logging": "npx playwright test example_structured_logging.spec.ts --ui",
    "test:ci": "CI=true npm test -- --reporter=junit",
    "ui-headed": "npx playwright test --ui",
    "google index": "npx playwright test --ui",
    "fetch_stocks": "npx playwright test ./tests_api/test_stocks_api.spec.ts --ui",
    "example_api": "npx playwright test --grep @example_api --reporter=html",
    "api_withoutlib": "npx playwright test --grep @api_withoutlib --project=chromium --reporter=html",
    "api_withlib_axios": "npx playwright test --grep @api_withlib_axios --project=chromium --reporter=html",
    "ui:prod": "npx playwright test tests/tests_ui/ --ui",
    "ui:dev": "TEST_ENV=dev npx playwright test tests/tests_ui/ --ui",
    "ui:test": "TEST_ENV=test npx playwright test tests/tests_ui/ --ui",
    "ui:stage": "TEST_ENV=stage npx playwright test tests/tests_ui/ --ui",
    "ui:prod:headed": "npx playwright test tests/tests_ui/ --headed",
    "ui:dev:headed": "TEST_ENV=dev npx playwright test tests/tests_ui/ --headed",
    "ui:test:headed": "TEST_ENV=test npx playwright test tests/tests_ui/ --headed",
    "ui:stage:headed": "TEST_ENV=stage npx playwright test tests/tests_ui/ --headed",
    "ui:sauce:prod": "npx playwright test tests/sauceDemo/ --ui",
    "ui:sauce:dev": "TEST_ENV=dev npx playwright test tests/sauceDemo/ --ui",
    "ui:sauce:test": "TEST_ENV=test npx playwright test tests/sauceDemo/ --ui",
    "ui:sauce:stage": "TEST_ENV=stage npx playwright test tests/sauceDemo/ --ui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BlockchainDeveloper009/testerUtils.git"
  },
  "keywords": [
    "playwright",
    "testing",
    "automation",
    "logging",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/BlockchainDeveloper009/testerUtils/issues"
  },
  "homepage": "https://github.com/BlockchainDeveloper009/testerUtils#readme",
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@playwright/test": "^1.34.1",
    "@types/node": "^25.3.3",
    "axios": "^1.4.0"
  },
  "dependencies": {
    "nodemailer": "^6.9.4",
    "playwright": "^1.58.2",
    "zod": "^4.3.6"
    "@types/eslint": "^8.56.5",
    "@types/node": "^22.13.9",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "prettier": "^3.2.5",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "nodemailer": "^6.9.4"
  }
}
