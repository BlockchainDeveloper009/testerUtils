# Environment Configuration Example
# Copy this file to .env and update with your actual values

# Base URL for test application
BASE_URL=http://localhost:3000

# Test Environment (dev, test, stage, prod)
ENV_LOC=dev

# API Configuration
API_BASE_URL=http://localhost:3001
API_TIMEOUT=30000

# Authentication
AUTH_TOKEN=
AUTH_USERNAME=
AUTH_PASSWORD=

# Feature Flags
DEBUG=false
SKIP_CONNECTIVITY_CHECK=false

# CI/CD Environment (automatically set by CI systems)
# CI=true
# NODE_ENV=test
